# Streamlit Community Cloud secrets.
#
# Paste the contents below into:  share.streamlit.io -> your app ->
#   Settings -> Secrets   (do NOT commit the real values; this is only a template)
#
# DATABASE_URL points the cloud app at your Supabase Postgres (the IPv4 session
# pooler — required because Streamlit Cloud can't reach Supabase's IPv6-only
# direct host).

DATABASE_URL = "postgresql://postgres.<project-ref>:<db-password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Optional: the cloud app generally can't log into Garmin (datacenter IPs are
# rate-limited). Garmin syncing is done by the local sync_job.py instead. You can
# still add these if you want the in-app "Sync" button to attempt it:
# GARMIN_EMAIL = "you@example.com"
# GARMIN_PASSWORD = "your-garmin-password"
